# API
API_PORT=3000
DATABASE_URL=postgresql://animaldot:animaldot@localhost:5432/animaldot
JWT_ACCESS_SECRET=aabbccddeeffgghhjjiillmmnnooppqqrrss
JWT_REFRESH_SECRET=ssrrqqppoonnmmlliijjhhggffeeddccbbaa
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development

# WebSocket path (same server as API)
WS_PATH=/vitals

# MQTT — default: UGA SensorWeb (change MQTT_GEOPHONE_DEVICE_ID to your ESP32 Wi‑Fi MAC).
# Topics default to /<MQTT_ORG>/<MAC>/geophone and /<MQTT_ORG>/<DHT_ID>/temperature
# unless you set MQTT_TOPIC_* explicitly.
MQTT_BROKER_URL=mqtt://sensorweb.us:1883
MQTT_ORG=sensorweb
MQTT_GEOPHONE_DEVICE_ID=3030f9723ae8
MQTT_DHT20_DEVICE_ID=DHT20
# Optional overrides:
# MQTT_TOPIC_GEOPHONE=/sensorweb/yourmac12hex/geophone
# MQTT_TOPIC_TEMPERATURE=/sensorweb/DHT20/temperature

